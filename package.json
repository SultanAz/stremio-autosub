{
  "name": "stremio-autosub",
  "version": "0.1.0",
  "private": true,
  "description": "Stremio subtitles addon with automatic per-episode sync (Arabic, multi-source, hash + release + framerate + alass)",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node-fetch": "^2.6.13",
    "@upstash/redis": "^1.38.0",
    "adm-zip": "^0.5.17",
    "ass-compiler": "^0.1.15",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lru-cache": "^11.0.2",
    "node-fetch": "^2.7.0",
    "parse-torrent-title": "^3.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "stremio-addon-sdk": "^1.6.10",
    "subtitle": "^4.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
