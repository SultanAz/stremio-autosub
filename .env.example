# Server
PORT=7777
NODE_ENV=development
LOG_LEVEL=info

# OpenSubtitles vNext (https://opensubtitles.com/en/consumers)
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USER_AGENT=stremio-autosub v0.1.0
# Optional account login for higher daily quota (20/day vs 5/day)
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# SubDL (https://subdl.com/api-doc)
SUBDL_API_KEY=

# Wyzie Subs (https://docs.wyzie.io/subs/intro) - optional, no key needed for basic usage
WYZIE_API_KEY=

# Upstash Redis (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Languages to fetch (comma-separated ISO 639-2)
SUB_LANGS=ara,eng

# Public URL of this addon (for serving cached SRTs back to Stremio)
# In production, set to https://your-app.beamup.dev
PUBLIC_URL=http://127.0.0.1:7777
